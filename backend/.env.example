# Copy this file to `.env` and fill in the values for your machine:
#
#     cd backend && cp .env.example .env
#
# `.env` is gitignored — never commit real keys.

# --- MobSF REST API ---
# Get the API key from the MobSF web UI (top-right, "API Key") once it's running.
MOBSF_API_KEY=replace-with-your-mobsf-api-key
MOBSF_URL=http://localhost:8000
MOBSF_HTTP_TIMEOUT=300

# --- Android emulator / dynamic analysis (optional) ---
# Only needed if you run dynamic analysis. Leave defaults if unsure.
EMULATOR_NAME=emulator-5554
MOBSF_ANALYZER_IDENTIFIER=emulator-5554
MOBSF_DYNAMIC_RUN_SECONDS=90

# --- Feature store (generated SQLite DB; created automatically) ---
FEATURE_STORE_DB=feature_store.sqlite

# --- LLM layer (local Ollama) ---
# Run `ollama serve` and `ollama pull gemma3` first. No API key needed.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
OLLAMA_TIMEOUT=600
